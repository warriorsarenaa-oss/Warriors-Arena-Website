# ============================================
# Site Configuration
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ============================================
# Business Contact (defaults shown to customers)
# ============================================
WHATSAPP_BUSINESS_NUMBER=+201XXXXXXXXX
INSTAPAY_IDENTIFIER=warriors@instapay
CONTACT_PHONE=+201XXXXXXXXX
CONTACT_EMAIL=hello@warriorsarena.example

# ============================================
# Meta Pixel & Conversions API
# ============================================
NEXT_PUBLIC_META_PIXEL_ID=YOUR_PIXEL_ID
META_CAPI_ACCESS_TOKEN=YOUR_CAPI_TOKEN
META_CAPI_TEST_EVENT_CODE=  # Optional, only for testing

# ============================================
# CAPTCHA (Cloudflare Turnstile recommended)
# ============================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================================
# Sentry
# ============================================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=  # For source map uploads in CI
SENTRY_ORG=
SENTRY_PROJECT=

# ============================================
# Initial Super Admin (used by seed migration)
# Change immediately after first login.
# ============================================
INITIAL_SUPER_ADMIN_USERNAME=warriors_admin
INITIAL_SUPER_ADMIN_EMAIL=youssef@warriorsarena.example
INITIAL_SUPER_ADMIN_PASSWORD=Warriors@26
INITIAL_SUPER_ADMIN_FULL_NAME=Youssef

# ============================================
# Cron Secret (used by Vercel Cron to authenticate)
# Generate with: openssl rand -hex 32
# ============================================
CRON_SECRET=

# ============================================
# v1.1+ Integrations (leave blank in v1)
# ============================================
PAYMOB_API_KEY=
PAYMOB_WEBHOOK_HMAC_SECRET=
PAYMOB_INTEGRATION_ID_INSTAPAY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_FAWRY=

WHATSAPP_API_PROVIDER=  # 'twilio' or '360dialog'
WHATSAPP_API_KEY=
WHATSAPP_API_SECRET=
WHATSAPP_FROM_NUMBER=

# ============================================
# Notes
# ============================================
# - Never commit this file with real values.
# - The boot validation in src/lib/env.ts requires all v1 variables to be set.
# - v1.1+ variables are optional in v1 (validated as optional in Zod schema).
